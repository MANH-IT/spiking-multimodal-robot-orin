# ---------- DATASETS & DATA ----------
data/
datasets/
*.zip
*.tar.gz
*.tar
*.h5
*.hdf5

# ---------- LOGS & EXPERIMENTS ----------
experiments/
runs/
logs/
*.log
tensorboard/
wandb/

# ---------- MODELS & WEIGHTS ----------
*.pth
*.pt
*.pkl
*.ckpt
*.safetensors
weights/
checkpoints/
models/saved/

# ---------- PYTHON CACHE ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# ---------- IDE & EDITORS ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ---------- ENVIRONMENT & CONFIG ----------
.env
.env.local
.venv/
venv/
ENV/
env/
*.local

# ---------- JUPYTER NOTEBOOKS ----------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------- TEMP FILES ----------
.tmp.driveupload/
*.tmp
*.temp
*.bak
*.backup

# ---------- JETSON SPECIFIC ----------
*.trt
*.engine
*.onnx
*.uff

# ---------- ROS2 ----------
install/
build/
log/
